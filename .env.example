ADMIN_API_KEY=

# Enable Real WDL house-booking (for later testing)
REAL_WDL_HOUSE_ENABLED=

# Bankroll and exposure caps (dev-safe defaults)
REAL_WDL_BANKROLL=
REAL_WDL_PER_GAME_CAP_PCT_OF_B=
REAL_WDL_PER_OUTCOME_CAP_PCT_OF_GAME_WHITE=
REAL_WDL_PER_OUTCOME_CAP_PCT_OF_GAME_BLACK=
REAL_WDL_PER_OUTCOME_CAP_PCT_OF_GAME_DRAW=
REAL_WDL_PER_BET_LIABILITY_CAP_PCT_OF_GAME=
REAL_WDL_PER_PLAYER_PER_GAME_CAP_PCT_OF_GAME=
REAL_WDL_GLOBAL_EXPOSURE_CAP_PCT=

# Pricing
REAL_WDL_MARGIN_BASE=
REAL_WDL_MARGIN_DRAW_EXTRA=
REAL_WDL_MAX_ODDS_WHITE=
REAL_WDL_MAX_ODDS_BLACK=
REAL_WDL_MAX_ODDS_DRAW=

# Confidence tuning
REAL_WDL_CONF_EARLY_MOVE_NUM=
REAL_WDL_CONF_CAP_MULT_EARLY=
REAL_WDL_CONF_MARGIN_EXTRA=

# Point backend to local microservice router base path (dev stage prefix)
MICROSERVICE_URL=
 
# Enable smarter featured-game selector (uses Lichess TV metadata only)
FEATURED_SELECTOR_ENABLED=

# Increase backend log verbosity during local debugging
LOG_LEVEL=

# Email (development): Ethereal test SMTP
# Emails are NOT delivered; view them in the Ethereal UI.
ETHEREAL_EMAIL=
ETHEREAL_PASSWORD=
# Frontend base URL for verification links
FRONTEND_URL=
EMAIL_FROM=

# Feature flags (defaults)
# Ensure email verification flows are enabled by default in dev
REQUIRE_EMAIL_VERIFICATION=
