  "license": "MIT",
  "scripts": {
    "lint": "eslint ./src",
    "test": "npm run lint && NODE_ENV=test jest --verbose --runInBand --detectOpenHandles",
    "dev": "nodemon --exec \"ts-node -r tsconfig-paths/register src/server.ts\"",
    "promote-admin": "ts-node -r tsconfig-paths/register scripts/promote-admin.ts",
    "create-invite": "ts-node -r tsconfig-paths/register scripts/create-invite.ts",
    "build": "rimraf dist && tsc --skipLibCheck --noEmitOnError false",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "prod": "node -r tsconfig-paths/register dist/server.js",
    "heroku-prebuild": "node heroku-prebuild.js",
    "heroku-postbuild": "npm run build",
    "deadcode:unimported": "unimported",
    "deadcode:tsprune": "ts-prune",
    "deadcode:depcheck": "depcheck",
    "deadcode:all": "npm run deadcode:unimported && npm run deadcode:tsprune && npm run deadcode:depcheck"
  },
  "dependencies": {
    "@axiomhq/axiom-node": "0.12.0",
