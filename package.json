{
  "name": "betmate-backend",
  "version": "2.0.8",
  "description": "API for BetMate",
  "productionURL": "https://betmate-backend-prod.herokuapp.com",
  "productionClientURL": "https://betmate-prod.netlify.app/",
  "main": "src/server.js",
  "engines": {
    "node": "18.x"
  },
  "repository": "https://github.com/dali-lab/betmate-backend",
  "author": "Jack Keane <John.F.Keane.22@Dartmouth.edu>",
  "contributors": [
    "Jack Keane <John.F.Keane.22@Dartmouth.edu>",
